{
  "name": "trae-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "aws:setup": "./scripts/setup-aws-credentials.sh",
    "aws:deploy": "./scripts/deploy-aws.sh --deploy",
    "aws:check": "./scripts/deploy-aws.sh --check",
    "aws:test": "./scripts/deploy-aws.sh --test",
    "aws:init": "npx ts-node src/scripts/init-aws.ts",
    "cdk:synth": "cd aws/infrastructure && npm run synth",
    "cdk:deploy": "cd aws/infrastructure && npm run deploy",
    "cdk:destroy": "cd aws/infrastructure && npm run destroy",
    "db:init": "psql -h $AWS_RDS_ENDPOINT -U $AWS_RDS_USERNAME -d $AWS_RDS_DATABASE -f src/database/init.sql"
  },
